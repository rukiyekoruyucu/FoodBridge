{
  "name": "foodbridge-backend-pro",
  "version": "1.0.0",
  "description": "FoodBridge backend - Node.js + Express + SQLite (better-sqlite3) + Firebase Auth",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "cross-env NODE_ENV=test jest --forceExit",
    "test:unit": "cross-env NODE_ENV=test jest tests/unit --forceExit",
    "test:integration": "cross-env NODE_ENV=test jest tests/integration --forceExit",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --forceExit",
    "lint": "echo \"no lint configured\""
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  }
}
